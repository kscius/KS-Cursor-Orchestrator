[
  {
    "prompt": "Add JSDoc to all exported functions",
    "files": "src/**/*.ts",
    "model": "gemini-3-flash"
  },
  {
    "prompt": "Check for missing error boundaries",
    "files": "src/components/**/*.tsx",
    "mode": "ask"
  },
  {
    "prompt": "Run a read-only security audit on auth flows",
    "files": "src/auth/**",
    "mode": "ask",
    "approveMcps": true,
    "sandbox": "enabled"
  },
  {
    "prompt": "Fix all lint errors in the API layer and apply changes",
    "files": "src/api/**/*.ts",
    "force": true,
    "trust": true,
    "sandbox": "enabled",
    "maxRetries": 1
  },
  {
    "prompt": "Continue the migration work from the previous session",
    "continue": true,
    "sandbox": "enabled"
  },
  {
    "prompt": "Audit the packages directory for outdated dependencies",
    "files": "packages/**/*.json",
    "mode": "ask",
    "cwd": "C:/path/to/repo",
    "workspace": "C:/path/to/repo",
    "outputFile": "reports/dependency-audit.txt"
  },
  {
    "prompt": "&Implement the full checkout flow described in TASK.md and open a PR",
    "cloud": true,
    "sandbox": "enabled",
    "cwd": "C:/path/to/repo",
    "maxRetries": 0
  }
]
