{
  "$schema": "https://unpkg.com/cursor-hooks@latest/schema/hooks.schema.json",
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node ./hooks/session-bootstrap.js",
        "timeout": 12,
        "failClosed": false
      },
      {
        "command": "node ./hooks/audit-log.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node ./hooks/after-agent-response.js",
        "timeout": 8,
        "failClosed": false
      }
    ],
    "afterAgentThought": [
      {
        "command": "node ./hooks/thought-logger.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "sessionEnd": [
      {
        "command": "node ./hooks/session-end.js",
        "timeout": 8,
        "failClosed": false
      },
      {
        "command": "node ./hooks/audit-log.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node ./hooks/auto-approve-safe.js",
        "timeout": 5,
        "failClosed": false
      },
      {
        "command": "node ./hooks/block-dangerous-shell.js",
        "timeout": 10
      },
      {
        "command": "node ./hooks/protect-branch.js",
        "matcher": "git"
      }
    ],
    "afterShellExecution": [
      {
        "command": "node ./hooks/audit-log.js",
        "timeout": 5,
        "failClosed": false
      },
      {
        "command": "node ./hooks/shell-result-hint.js",
        "timeout": 8,
        "failClosed": false,
        "matcher": "npm|yarn|pnpm|bun|jest|vitest|pytest|rspec|cargo|go test|make|tsc|eslint|prettier|docker|git push|git pull|git merge|git rebase|migrate|prisma|dotnet|mvn|gradle|mix|bundle|pip|poetry|pdm|uv|flutter|dart|ruby|rake|phpunit|composer"
      }
    ],
    "beforeReadFile": [
      {
        "command": "node ./hooks/block-secret-reads.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "beforeTabFileRead": [
      {
        "command": "node ./hooks/block-secret-reads.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": "node ./hooks/edit-tracker.js",
        "timeout": 5,
        "failClosed": false
      },
      {
        "command": "node ./hooks/post-edit-quality.js",
        "timeout": 10,
        "failClosed": false
      },
      {
        "command": "node ./hooks/comment-checker.js",
        "timeout": 8,
        "failClosed": false
      },
      {
        "command": "node ./hooks/dependency-guard.js",
        "timeout": 10,
        "failClosed": false,
        "matcher": "\\.(ts|tsx|js|jsx|mjs|cjs|py)$"
      },
      {
        "command": "node ./hooks/auto-format.js",
        "timeout": 15,
        "failClosed": false
      },
      {
        "command": "node ./hooks/typescript-quality-cache.js",
        "timeout": 15,
        "failClosed": false,
        "matcher": "\\.(ts|tsx)$"
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "node ./hooks/post-edit-quality.js",
        "timeout": 10,
        "failClosed": false
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node ./hooks/validate-mcp.js",
        "timeout": 10,
        "failClosed": false
      },
      {
        "command": "node ./hooks/prompt-injection-scanner.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterMCPExecution": [
      {
        "command": "node ./hooks/mcp-result-hint.js",
        "timeout": 8,
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "command": "node ./hooks/tdd-guard.js",
        "timeout": 8,
        "failClosed": false,
        "matcher": "Write"
      },
      {
        "command": "node ./hooks/audit-log.js",
        "timeout": 5,
        "failClosed": false,
        "matcher": "Shell|Write|Delete"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "node ./hooks/tool-failure-tracker.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "subagentStart": [
      {
        "command": "node ./hooks/subagent-guard.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "subagentStop": [
      {
        "command": "node ./hooks/subagent-complete.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": "node ./hooks/stop-summary.js",
        "timeout": 10,
        "failClosed": false
      },
      {
        "command": "node ./hooks/verifier.js",
        "timeout": 90,
        "failClosed": false
      },
      {
        "command": "node ./hooks/boulder-check.js",
        "timeout": 15,
        "failClosed": false
      },
      {
        "command": "node ./hooks/audit-log.js",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "preCompact": [
      {
        "command": "node ./hooks/precompact-preserve.js",
        "timeout": 15,
        "failClosed": false
      }
    ]
  }
}
